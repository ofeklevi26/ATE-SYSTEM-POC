<Window x:Class="Ate.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ATE UI" Height="420" Width="760">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Device Type"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  Margin="0,0,0,8"
                  ItemsSource="{Binding Devices}"
                  SelectedItem="{Binding SelectedDevice, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Operation"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  Margin="0,0,0,8"
                  ItemsSource="{Binding Operations}"
                  SelectedItem="{Binding SelectedOperation, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Top" Text="Parameters"/>
        <Border Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" BorderBrush="#DDD" BorderThickness="1" Padding="8">
            <ItemsControl ItemsSource="{Binding ParameterInputs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Name}"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="Gray" Text="{Binding Type}"/>
                            <TextBox Grid.Column="2" Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,8">
            <Button Width="90" Margin="0,0,8,0" Content="Send" Command="{Binding SendCommand}"/>
            <Button Width="90" Margin="0,0,8,0" Content="Pause" Command="{Binding PauseCommand}"/>
            <Button Width="90" Margin="0,0,8,0" Content="Resume" Command="{Binding ResumeCommand}"/>
            <Button Width="90" Margin="0,0,8,0" Content="Clear" Command="{Binding ClearCommand}"/>
            <Button Width="120" Content="Abort Current" Command="{Binding AbortCommand}"/>
        </WrapPanel>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Vertical">
            <TextBlock Text="Status" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding StatusText}" IsReadOnly="True" AcceptsReturn="True" Height="130" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
